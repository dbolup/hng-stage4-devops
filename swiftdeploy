#!/usr/bin/env python3

import sys
import os
import yaml
import subprocess
import time
import socket
import urllib.request
import urllib.error
import json

MANIFEST = "manifest.yaml"
NGINX_CONF = "nginx.conf"
COMPOSE_FILE = "docker-compose.yml"
NGINX_TEMPLATE = "templates/nginx.conf.j2"
COMPOSE_TEMPLATE = "templates/docker-compose.yml.j2"


# ── Helpers ──────────────────────────────────────────────────

def load_manifest():
    with open(MANIFEST) as f:
        return yaml.safe_load(f)


def render_template(template_path, context):
    """Simple template renderer — replaces {{ key.subkey }} tokens."""
    with open(template_path) as f:
        content = f.read()

    def resolve(match_str, ctx):
        """Resolve dot-notation key from context dict."""
        keys = match_str.strip().split(".")
        val = ctx
        for k in keys:
            val = val[k]
        return str(val)

    import re
    pattern = re.compile(r"\{\{\s*([\w.]+)\s*\}\}")

    def replacer(match):
        try:
            return resolve(match.group(1), context)
        except (KeyError, TypeError):
            return match.group(0)

    return pattern.sub(replacer, content)


def run(cmd, check=True, capture=False):
    result = subprocess.run(
        cmd, shell=True, check=check,
        capture_output=capture, text=True
    )
    return result


def ok(msg):
    print(f"  \033[32m✔\033[0m  {msg}")


def fail(msg):
    print(f"  \033[31m✘\033[0m  {msg}")


def info(msg):
    print(f"  \033[34m→\033[0m  {msg}")


def header(msg):
    print(f"\n\033[1m{msg}\033[0m")
    print("─" * 50)


# ── INIT ─────────────────────────────────────────────────────

def cmd_init():
    header("swiftdeploy init")
    manifest = load_manifest()

    # Render nginx.conf
    nginx_out = render_template(NGINX_TEMPLATE, manifest)
    with open(NGINX_CONF, "w") as f:
        f.write(nginx_out)
    ok(f"Generated {NGINX_CONF}")

    # Render docker-compose.yml
    compose_out = render_template(COMPOSE_TEMPLATE, manifest)
    with open(COMPOSE_FILE, "w") as f:
        f.write(compose_out)
    ok(f"Generated {COMPOSE_FILE}")

    print()


# ── VALIDATE ─────────────────────────────────────────────────

def cmd_validate():
    header("swiftdeploy validate")
    passed = 0
    failed = 0

    # Check 1: manifest.yaml exists and is valid YAML
    try:
        manifest = load_manifest()
        ok("manifest.yaml exists and is valid YAML")
        passed += 1
    except FileNotFoundError:
        fail("manifest.yaml not found")
        failed += 1
        manifest = None
    except yaml.YAMLError as e:
        fail(f"manifest.yaml is invalid YAML: {e}")
        failed += 1
        manifest = None

    # Check 2: All required fields present and non-empty
    required = {
        "services.image": ["services", "image"],
        "services.port":  ["services", "port"],
        "nginx.image":    ["nginx", "image"],
        "nginx.port":     ["nginx", "port"],
        "network.name":   ["network", "name"],
        "network.driver_type": ["network", "driver_type"],
    }
    all_fields_ok = True
    if manifest:
        for label, keys in required.items():
            val = manifest
            try:
                for k in keys:
                    val = val[k]
                if not val and val != 0:
                    raise ValueError("empty")
            except (KeyError, TypeError, ValueError):
                fail(f"Required field missing or empty: {label}")
                failed += 1
                all_fields_ok = False
        if all_fields_ok:
            ok("All required fields present and non-empty")
            passed += 1

    # Check 3: Docker image exists locally
    if manifest:
        image = manifest["services"]["image"]
        result = run(
            f"docker image inspect {image}",
            check=False, capture=True
        )
        if result.returncode == 0:
            ok(f"Docker image '{image}' exists locally")
            passed += 1
        else:
            fail(f"Docker image '{image}' not found locally — run: docker build -t {image} .")
            failed += 1

    # Check 4: Nginx port not already bound
    if manifest:
        port = int(manifest["nginx"]["port"])
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            result = s.connect_ex(("localhost", port))
        if result != 0:
            ok(f"Nginx port {port} is free")
            passed += 1
        else:
            fail(f"Port {port} is already in use")
            failed += 1

    # Check 5: nginx.conf is syntactically valid
    # Note: upstream DNS (api:port) only resolves inside the full stack network.
    # We validate syntax only — upstream resolution errors are expected and ignored.
    if os.path.exists(NGINX_CONF):
        result = run(
            f"docker run --rm -v $(pwd)/nginx.conf:/etc/nginx/conf.d/default.conf:ro nginx:latest nginx -t 2>&1 || true",
            check=False, capture=True
        )
        output = result.stdout + result.stderr
        # Only fail on real syntax errors, not upstream DNS resolution
        real_errors = [
            line for line in output.splitlines()
            if "emerg" in line or "error" in line
            if "host not found in upstream" not in line
            if "connect() failed" not in line
        ]
        if not real_errors:
            ok("nginx.conf syntax is valid")
            passed += 1
        else:
            fail(f"nginx.conf syntax error:\n" + "\n".join(real_errors))
            failed += 1
    else:
        fail("nginx.conf not found — run: ./swiftdeploy init first")
        failed += 1

    # Summary
    print()
    print(f"  Results: {passed} passed, {failed} failed")
    if failed > 0:
        print()
        sys.exit(1)
    else:
        ok("All checks passed!")
        print()


# ── DEPLOY ───────────────────────────────────────────────────

def cmd_deploy():
    header("swiftdeploy deploy")

    # Run init first
    cmd_init()

    # Bring up the stack
    info("Starting containers...")
    run("docker compose up -d --build")

    # Wait for health checks
    manifest = load_manifest()
    port = manifest["nginx"]["port"]
    url = f"http://localhost:{port}/healthz"

    info(f"Waiting for health check at {url} ...")
    deadline = time.time() + 60

    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=3) as resp:
                data = json.loads(resp.read())
                if data.get("status") == "ok":
                    ok(f"Stack is healthy! mode={data.get('mode')} uptime={data.get('uptime_seconds')}s")
                    print()
                    run("docker compose ps")
                    return
        except Exception:
            pass
        time.sleep(3)

    fail("Health check timed out after 60 seconds")
    run("docker compose logs --tail=20", check=False)
    sys.exit(1)


# ── PROMOTE ──────────────────────────────────────────────────

def cmd_promote(mode):
    if mode not in ("canary", "stable"):
        fail(f"Invalid mode '{mode}' — use: canary or stable")
        sys.exit(1)

    header(f"swiftdeploy promote {mode}")

    # Update manifest.yaml in-place
    with open(MANIFEST) as f:
        content = f.read()

    import re
    new_content = re.sub(
        r"(mode:\s*)(\S+)",
        f"\\g<1>{mode}",
        content
    )
    with open(MANIFEST, "w") as f:
        f.write(new_content)
    ok(f"Updated manifest.yaml → mode: {mode}")

    # Regenerate docker-compose.yml
    cmd_init()

    # Restart only the api container
    info("Restarting API container...")
    run("docker compose up -d --no-deps --build api")

    # Wait and confirm new mode
    manifest = load_manifest()
    port = manifest["nginx"]["port"]
    url = f"http://localhost:{port}/healthz"

    info("Confirming new mode via /healthz ...")
    deadline = time.time() + 60

    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=3) as resp:
                data = json.loads(resp.read())
                current_mode = data.get("mode")
                if current_mode == mode:
                    ok(f"Mode confirmed: {current_mode}")
                    ok(f"Uptime: {data.get('uptime_seconds')}s")
                    print()
                    return
        except Exception:
            pass
        time.sleep(3)

    fail("Could not confirm new mode within 60 seconds")
    sys.exit(1)


# ── TEARDOWN ─────────────────────────────────────────────────

def cmd_teardown(clean=False):
    header("swiftdeploy teardown")

    info("Stopping and removing containers, networks, volumes...")
    run("docker compose down -v --remove-orphans", check=False)
    ok("Stack torn down")

    if clean:
        for f in [NGINX_CONF, COMPOSE_FILE]:
            if os.path.exists(f):
                os.remove(f)
                ok(f"Deleted {f}")
        ok("Generated configs deleted")

    print()


# ── ENTRYPOINT ───────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    if not args:
        print("Usage: ./swiftdeploy <command> [options]")
        print()
        print("Commands:")
        print("  init                  Generate nginx.conf and docker-compose.yml")
        print("  validate              Run pre-flight checks")
        print("  deploy                Init, start stack, wait for health")
        print("  promote <canary|stable>  Switch deployment mode")
        print("  teardown [--clean]    Stop stack, optionally delete configs")
        print()
        sys.exit(0)

    command = args[0]

    if command == "init":
        cmd_init()
    elif command == "validate":
        cmd_validate()
    elif command == "deploy":
        cmd_deploy()
    elif command == "promote":
        if len(args) < 2:
            fail("Usage: ./swiftdeploy promote <canary|stable>")
            sys.exit(1)
        cmd_promote(args[1])
    elif command == "teardown":
        cmd_teardown(clean="--clean" in args)
    else:
        fail(f"Unknown command: {command}")
        sys.exit(1)


if __name__ == "__main__":
    main()
